# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=pharmaops

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
